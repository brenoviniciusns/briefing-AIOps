# Copia para .env na raiz deste repositório (run-n8n-mcp.cmd faz cd para aqui antes do npx).
N8N_API_URL=https://brenoviniciusns.app.n8n.cloud

# Obrigatório para ferramentas de workflow (n8n_list_workflows, etc.):
# n8n Cloud → Settings → n8n API → Create API key
N8N_API_KEY=

# Alternativa: %USERPROFILE%\.cursor\n8n-api-key.txt com a chave numa linha (n8n-api-key.README.txt).
